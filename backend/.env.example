# MetaGPT Backend Configuration
# Copy this file to .env and fill in your values

# Google API Key for Gemini 3
# Get your API key from: https://makersuite.google.com/app/apikey
GOOGLE_API_KEY=your-google-api-key-here

# Application Settings
DEBUG=false
APP_NAME=MetaGPT
APP_VERSION=0.1.0

# API Settings
API_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# MongoDB Settings
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB=metagpt

# JWT Authentication
JWT_SECRET=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Credits (free projects for new users)
FREE_CREDITS=2

# LLM Settings
LLM_MODEL=gemini-3-pro-preview
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=8192
LLM_TIMEOUT=120

# Storage Settings (file-based storage for generated code files)
PROJECTS_DIR=./projects
STORAGE_TYPE=file

# Agent Settings
AGENT_MAX_RETRIES=3
AGENT_RETRY_DELAY=1.0

# E2B Sandbox (for live preview after deployment)
# Get your API key from: https://e2b.dev/dashboard?tab=keys
E2B_API_KEY=your-e2b-api-key-here
E2B_SANDBOX_TIMEOUT=300

RAG_ENABLED=true
RAG_CHUNK_SIZE=1500
RAG_CHUNK_OVERLAP=200
RAG_TOP_K=8
RAG_EMBEDDING_MODEL=gemini-embedding-001
